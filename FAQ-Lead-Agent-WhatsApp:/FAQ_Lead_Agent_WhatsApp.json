    {
      "parameters": {
        "jsCode": "const output = $('AI Agent').item.json.output;\n\nconst match = output.match(/LEAD_DATA:(\\{.*\\})/);\n\nif (match) {\n  const leadData = JSON.parse(match[1]);\n  const mensaje = output.replace(/LEAD_DATA:\\{.*\\}/, '').trim();\n  const leadCompleto = leadData.prenda && leadData.talle && leadData.color;\n\n  return [{\n    json: {\n      prenda: leadData.prenda || '',\n      talle: leadData.talle || '',\n      color: leadData.color || '',\n      resumen: leadData.resumen || '',\n      telefono: $('Edit Fields').item.json.telefono,\n      fecha: new Date().toISOString(),\n      mensaje: mensaje,\n      guardar_en_sheets: leadCompleto ? true : false\n    }\n  }];\n} else {\n  return [{\n    json: {\n      prenda: '',\n      talle: '',\n      color: '',\n      resumen: '',\n      telefono: $('Edit Fields').item.json.telefono,\n      fecha: new Date().toISOString(),\n      mensaje: output,\n      guardar_en_sheets: false\n    }\n  }];\n}"
      },
